{
  "build": {
    "builder": "python builder",
    "python": {
      "version": "3.11.8"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

{
  "deploy": {
    "startCommand": "gunicorn Main.wsgi:application --bind 0.0.0.0:$PORT",
    "healthcheckPath": "/health"
  }
}